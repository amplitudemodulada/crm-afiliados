<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Afiliados - CRM Pro</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial; background: #f5f5f5; }
    .nav { background: #007bff; padding: 15px; display: flex; gap: 20px; }
    .nav a { color: white; text-decoration: none; padding: 10px 20px; border-radius: 4px; }
    .nav a:hover, .nav a.active { background: rgba(255,255,255,0.2); }
    .container { max-width: 1400px; margin: 30px auto; padding: 0 20px; }
    .grid { display: grid; grid-template-columns: 1fr 2fr; gap: 30px; }
    .card { background: white; padding: 25px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    h1 { margin-bottom: 20px; color: #333; }
    h2 { color: #555; margin-bottom: 15px; font-size: 18px; }
    form input, form select, form button { width: 100%; padding: 10px; margin: 8px 0; border: 1px solid #ddd; border-radius: 4px; }
    form button { background: #007bff; color: white; border: none; cursor: pointer; font-weight: bold; }
    form button:hover { background: #0056b3; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }
    th { background: #f8f9fa; color: #333; font-weight: bold; }
    td a { color: #007bff; text-decoration: none; }
    td a:hover { text-decoration: underline; }
    .status-ativo { color: green; font-weight: bold; }
    .status-inativo { color: red; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; }
    .badge-atraso { background: #f8d7da; color: #721c24; }
    .badge-em_dia { background: #d4edda; color: #155724; }
    .badge-sem_mensalidade { background: #e2e3e5; color: #383d41; }
  </style>
</head>
<body>
  <div class="nav">
    <a href="/dashboard" class="<%= nav.dashboard %>">Dashboard</a>
    <a href="/afiliados" class="<%= nav.afiliados %>">Afiliados</a>
    <a href="/financeiro" class="<%= nav.financeiro %>">Financeiro</a>
    <a href="/relatorios" class="<%= nav.relatorios %>">Relatórios</a>
    <a href="/backup" class="<%= nav.backup %>">Backup</a>
    <div style="margin-left: auto;">
      <a href="/admin-logout" style="color: rgba(255,255,255,0.8); text-decoration: none; font-size: 13px; padding: 6px 12px; border-radius: 4px; background: rgba(255,255,255,0.1);">Sair</a>
    </div>
    <a href="/logout" style="background: rgba(220,53,69,0.8);">Sair</a>
  </div>

  <div class="container">
    <h1>CRM Pro - Cadastro de Afiliados</h1>

    <div class="grid">
       <div class="card">
        <h2>Novo Afiliado</h2>
        <form method="POST" action="/afiliados">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input name="nome" placeholder="Nome Completo" required>
          <input name="email" placeholder="Email" type="email">
          <input name="telefone" placeholder="Telefone">
          <input name="cpf" placeholder="CPF">
          <input name="endereco" placeholder="Endereço Residencial">
          <input name="valor_mensalidade" type="number" step="0.01" min="0" placeholder="Valor da Mensalidade (R$)" required>
          <button>Salvar Afiliado</button>
        </form>
      </div>

      <div class="card">
        <h2>Lista de Afiliados</h2>
        <table>
          <tr><th>Nome</th><th>Email</th><th>Telefone</th><th>Endereço</th><th>Status</th><th>Mensalidade</th><th>Ações</th></tr>
           <% afiliados.forEach(a => { %>
             <tr>
               <td><a href="/afiliados/<%= a.id %>"><%= a.nome %></a></td>
               <td><%= a.email %></td>
               <td><%= a.telefone %></td>
               <td><%= a.endereco || '-' %></td>
               <td class="status-<%= a.status %>"><%= a.status %></td>
               <td>
                 <% if (a.situacao_mensalidade === 'atraso') { %>
                   <span class="badge badge-atraso">Em atraso</span>
                 <% } else if (a.situacao_mensalidade === 'em_dia') { %>
                   <span class="badge badge-em_dia">Em dia</span>
                 <% } else { %>
                   <span class="badge badge-sem_mensalidade">Sem registro</span>
                 <% } %>
               </td>
               <td>
                 <button
                   data-afiliado="<%= JSON.stringify({id: a.id, nome: a.nome, email: a.email, telefone: a.telefone, cpf: a.cpf, endereco: a.endereco || '', status: a.status}) %>"
                   onclick="editarAfiliado(this)"
                   style="background:#ffc107;color:#000;padding:5px 10px;border:none;border-radius:3px;cursor:pointer;margin-right:5px;">Editar</button>
                 <form method="POST" action="/afiliados/<%= a.id %>/delete" style="display:inline;" onsubmit="return confirm('Confirmar exclusão?')">
                   <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                   <button style="background:#dc3545;color:white;padding:5px 10px;border:none;border-radius:3px;cursor:pointer;">Excluir</button>
                 </form>
               </td>
             </tr>
           <% }) %>
        </table>
      </div>
    </div>

     <div class="card" id="editForm" style="display:none; margin-top:20px;">
      <h2>Editar Afiliado</h2>
      <form method="POST" id="formEditar">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="id" id="editId">
        <input name="nome" id="editNome" placeholder="Nome Completo" required>
        <input name="email" id="editEmail" placeholder="Email" type="email">
        <input name="telefone" id="editTelefone" placeholder="Telefone">
        <input name="cpf" id="editCpf" placeholder="CPF">
        <input name="endereco" id="editEndereco" placeholder="Endereço Residencial">
        <select name="status" id="editStatus">
          <option value="ativo">Ativo</option>
          <option value="inativo">Inativo</option>
        </select>
        <button type="submit">Salvar Alterações</button>
        <button type="button" onclick="cancelarEdicao()" style="background:#6c757d;">Cancelar</button>
      </form>
    </div>
  </div>

  <script>
    function editarAfiliado(btn) {
      const data = JSON.parse(btn.dataset.afiliado);
      document.getElementById('editForm').style.display = 'block';
      document.getElementById('formEditar').action = '/afiliados/' + data.id + '/edit';
      document.getElementById('editNome').value = data.nome;
      document.getElementById('editEmail').value = data.email;
      document.getElementById('editTelefone').value = data.telefone;
      document.getElementById('editCpf').value = data.cpf;
      document.getElementById('editEndereco').value = data.endereco;
      document.getElementById('editStatus').value = data.status;
    }
    function cancelarEdicao() {
      document.getElementById('editForm').style.display = 'none';
    }
  </script>

  <footer style="background: rgba(0,0,0,0.8); color: rgba(255,255,255,0.8); padding: 20px; text-align: center; margin-top: 40px;">
    <p style="font-size: 13px; margin-bottom: 5px;"><strong>Direitos do Sistema:</strong> Desenvolvimento Msdos Informática</p>
    <p style="font-size: 13px;">Suporte: <a href="mailto:suporte@msdosinformatica.com.br" style="color: #4facfe;">suporte@msdosinformatica.com.br</a></p>
  </footer>
</body>
</html>
